# Copy to .envrc, fill in values, then run: direnv allow
# Requires direnv: https://direnv.net/

# Postgres (Cloud SQL)
# Cloud Run / socket: postgresql://USER:PASSWORD@/DBNAME?host=/cloudsql/PROJECT:REGION:INSTANCE
# Local via Auth Proxy on localhost: postgresql://USER:PASSWORD@127.0.0.1:5432/DBNAME
export DATABASE_URL=postgresql://postgres:your-password@/postgres?host=/cloudsql/PROJECT:REGION:INSTANCE

# Aquifer API
export AQUIFER_API_KEY=your-aquifer-api-key
export AQUIFER_BASE_URL=https://api.aquifer.bible

# Application Configuration
export ENVIRONMENT=development
export LOG_LEVEL=INFO

# CORS Configuration (comma-separated)
export CORS_ORIGINS=http://localhost:3000,http://localhost:5173
