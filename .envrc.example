# Copy to .envrc, fill in values, then run: direnv allow
# Requires direnv: https://direnv.net/

# Postgres (Cloud SQL)
# Cloud Run (socket — attach instance hackathon-2026-503015:us-central1:dora):
#   postgresql://USER:PASSWORD@/DBNAME?host=/cloudsql/PROJECT:REGION:INSTANCE
# Local (Cloud SQL Auth Proxy on 127.0.0.1:5432):
#   postgresql://USER:PASSWORD@127.0.0.1:5432/DBNAME
export DATABASE_URL=postgresql://postgres:your-password@/postgres?host=/cloudsql/hackathon-2026-503015:us-central1:dora
# Used by `make db` so psql can skip the password prompt
export DATABASE_PASSWORD=your-password

# Aquifer API
export AQUIFER_API_KEY=your-aquifer-api-key
export AQUIFER_BASE_URL=https://api.aquifer.bible

# Gemini — pick one auth method:
# 1) AI Studio API key (if your org allows it):
# export GEMINI_API_KEY=your-gemini-api-key
#
# 2) Vertex AI with Application Default Credentials (recommended for YouVersion GCP):
#    Run: gcloud auth application-default login
#    Credentials are read from ~/.config/gcloud/application_default_credentials.json
export GEMINI_USE_VERTEX=true
export GEMINI_PROJECT=hackathon-2026-503015
export GEMINI_LOCATION=us-central1
export GEMINI_MODEL=gemini-2.5-flash

# Application Configuration
export ENVIRONMENT=development
export LOG_LEVEL=INFO

# CORS Configuration (comma-separated)
export CORS_ORIGINS=http://localhost:3000,http://localhost:5173
