# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# Aquifer API
AQUIFER_API_KEY=your-aquifer-api-key
AQUIFER_BASE_URL=https://api.aquifer.bible

# Application Configuration
ENVIRONMENT=development
LOG_LEVEL=INFO

# CORS Configuration (comma-separated; set your Vercel URL in production)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Server (optional locally; Render sets PORT and ENVIRONMENT=production)
# SERVER_HOST=127.0.0.1
# SERVER_PORT=8000
