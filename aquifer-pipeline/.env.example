# Copy to .env (loaded automatically from this directory): cp .env.example .env

# Postgres target for the loader (build_sql --run / run_sql / import_all).
# Local via Cloud SQL Auth Proxy:
#   cloud-sql-proxy hackathon-2026-503015:us-central1:dora --port 5432
DATABASE_URL=postgresql://postgres:your-password@127.0.0.1:5432/postgres
# Optional: a session-mode DSN preferred over DATABASE_URL for the multi-statement loader.
# DIRECT_URL=

# Aquifer API. Optional — the downloader falls back to the public web key + api-bn base.
AQUIFER_API_KEY=your-aquifer-api-key
AQUIFER_BASE_URL=https://api-bn.aquifer.bible
